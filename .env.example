# ── OpenMP / Runtime (CRITICAL for macOS) ────────────────────
# Prevents "OMP: Error #15" crash from duplicate libomp in
# torch + faiss-cpu + scikit-learn
KMP_DUPLICATE_LIB_OK=TRUE
OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

# ── Application ──────────────────────────────────────────────
APP_NAME=hr-rag-chatbot
ENVIRONMENT=development
API_PORT=8000
DEBUG=false

# ── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-256-bit-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8001/v1

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=768

# ── Vector Store ─────────────────────────────────────────────
VECTOR_STORE_BACKEND=faiss
FAISS_INDEX_DIR=./data/faiss_index

# ── Database ─────────────────────────────────────────────────
DB_PATH=./data/hr_chatbot.db

# ── RAG Pipeline ─────────────────────────────────────────────
DENSE_TOP_K=20
BM25_TOP_K=20
RERANK_TOP_N=8
MAX_CONTEXT_TOKENS=3000
LLM_TEMPERATURE=0.1
MAX_RESPONSE_TOKENS=1024

# ── Company ──────────────────────────────────────────────────
COMPANY_NAME=Acme Corp
HR_CONTACT_EMAIL=your HR department
